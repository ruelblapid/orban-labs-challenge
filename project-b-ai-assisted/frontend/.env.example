# Copy this file to .env.local and fill in real values. .env.local is gitignored.
# Both variables are server-only (no NEXT_PUBLIC_ prefix) — they're read only
# by the route handlers under app/api/, never shipped to the browser.

# Base URL of the FastAPI backend.
BACKEND_URL=http://localhost:8000

# Must match the backend's API_KEY (see backend/.env.example).
BACKEND_API_KEY=changeme-generate-a-real-secret
