# Copy this file to .env and fill in real values. .env is gitignored.

# Required. Clients must send this value in the X-API-Key header to create
# short URLs or read stats. Generate one with, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=changeme-generate-a-real-secret

# Optional. Path to the SQLite database file, relative to backend/ unless
# absolute. Defaults to urls.db.
DATABASE_PATH=urls.db

# Optional. Public base URL this API is served from, used to build the
# short_url returned to clients and to reject links that point back at the
# service itself. Defaults to http://localhost:8000.
BASE_URL=http://localhost:8000
